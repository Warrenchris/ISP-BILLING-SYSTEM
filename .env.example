# Copy this file to `.env` in this same directory (repository root).
# Docker Compose reads `.env` here for variable substitution into services.
# Do not commit the real `.env` file.

# M-Pesa / Safaricom Daraja (injected into `isp-backend` by docker-compose.yml)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox

# Optional aliases (MpesaService also reads these if set)
# MPESA_BUSINESS_SHORT_CODE=your_shortcode
# MPESA_PASS_KEY=your_passkey
